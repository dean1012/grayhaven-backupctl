def bash_completion_script() -> str:
    """Return bash completion for operator-facing command options."""

    return r"""# bash completion for grayhaven-backupctl
_grayhaven_backupctl()
{
    local cur prev words cword command
    _init_completion || return

    local global_opts="--verbose --help"
    local commands="list ls find restore backup completion"
    local find_opts="--repo --path --path-file --since --until --help"
    local repos="all local remote"
    local restore_opts="--repo --path --path-file --since --until --as-of"
    restore_opts="$restore_opts --target --in-place --force --help"

    command=""
    for word in "${words[@]:1:cword-1}"; do
        case "$word" in
            list|ls|find|restore|backup|completion)
                command="$word"
                break
                ;;
        esac
    done

    case "$prev" in
        --repo)
            COMPREPLY=( $(compgen -W "$repos" -- "$cur") )
            return
            ;;
        --since|--until|--as-of)
            return
            ;;
        --path|--path-file|--target)
            _filedir
            return
            ;;
    esac

    if [[ -z "$command" ]]; then
        COMPREPLY=( $(compgen -W "$global_opts $commands" -- "$cur") )
        return
    fi

    case "$command" in
        list)
            COMPREPLY=( $(compgen -W "--repo --since --until --help" -- "$cur") )
            ;;
        ls)
            COMPREPLY=( $(compgen -W "--repo --path --recursive --help" -- "$cur") )
            ;;
        find)
            COMPREPLY=( $(compgen -W "$find_opts" -- "$cur") )
            ;;
        restore)
            COMPREPLY=( $(compgen -W "$restore_opts" -- "$cur") )
            ;;
        backup)
            COMPREPLY=( $(compgen -W "--repo --help" -- "$cur") )
            ;;
        completion)
            COMPREPLY=( $(compgen -W "bash --help" -- "$cur") )
            ;;
    esac
}
complete -F _grayhaven_backupctl grayhaven-backupctl
"""


# ---------------------------------------------------------------------------
# Command-line parser
# ---------------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="grayhaven-backupctl",
        description="Manage Grayhaven local and remote restic backups.",
    )
    parser.add_argument(
        "--verbose", action="store_true", help="show detailed command feedback"
    )

    subparsers = parser.add_subparsers(dest="command")

    list_parser = subparsers.add_parser("list", help="list available backups")
    add_repo_option(list_parser)
    add_time_options(list_parser)

    ls_parser = subparsers.add_parser("ls", help="list files in a backup")
    ls_parser.add_argument(
        "snapshot", nargs="?", default="latest", help="snapshot ID or latest"
    )
    ls_parser.add_argument("--path", required=True, help="file or directory to list")
    ls_parser.add_argument(
        "--recursive", action="store_true", help="list directory contents recursively"
    )
    add_repo_option(ls_parser)

    find_parser = subparsers.add_parser("find", help="find backups containing paths")
    add_repo_option(find_parser)
    add_path_options(find_parser)
    add_time_options(find_parser)

    restore_parser = subparsers.add_parser(
        "restore", help="restore files or directories"
    )
    restore_parser.add_argument(
        "snapshot", nargs="?", default="latest", help="snapshot ID or latest"
    )
    add_repo_option(restore_parser)
    add_path_options(restore_parser)
    add_time_options(restore_parser)
    restore_parser.add_argument(
        "--as-of",
        help=(
            "restore from the closest matching backup at or before a time "
            'such as "3 days ago"'
        ),
    )
    target_group = restore_parser.add_mutually_exclusive_group()
    target_group.add_argument("--target", help="restore under this directory")
    target_group.add_argument(
        "--in-place", action="store_true", help="restore to original paths"
    )
    restore_parser.add_argument(
        "--force", action="store_true", help="overwrite without prompting"
    )

    backup_parser = subparsers.add_parser("backup", help="create a new backup")
    add_repo_option(backup_parser)

    completion_parser = subparsers.add_parser(
        "completion", help="print shell completion script"
    )
    completion_parser.add_argument(
        "shell", choices=("bash",), help="shell to generate completion for"
    )

    return parser


def add_repo_option(parser: argparse.ArgumentParser) -> None:
    parser.add_argument(
        "--repo",
        choices=("all", "local", "remote"),
        default="all",
        help="repository to use (default: all)",
    )


def add_time_options(parser: argparse.ArgumentParser) -> None:
    parser.add_argument(
        "--since", help='include backups since a time such as "2 days ago"'
    )
    parser.add_argument(
        "--until", help='include backups until a time such as "2026-06-27 8:00 AM"'
    )


def add_path_options(parser: argparse.ArgumentParser) -> None:
    parser.add_argument(
        "--path", action="append", help="file, directory, or glob to process"
    )
    parser.add_argument("--path-file", help="file containing one path per line")


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.command is None:
        parser.print_help()
        return 0

    try:
        if args.command == "completion":
            if args.shell == "bash":
                print(bash_completion_script(), end="")
            return 0

        service = BackupService(BackupConfig.from_backup_script())
        if args.command == "list":
            print_snapshots(
                service.snapshots(
                    args.repo,
                    since=parse_human_time(args.since),
                    until=parse_human_time(args.until),
                )
            )
        elif args.command == "ls":
            requested_path = resolve_operator_path(args.path)
            matches = service.find_matches(args.repo, [requested_path])
            selected = next(
                (
                    match
                    for match in matches
                    if args.snapshot == "latest"
                    or snapshot_matches(args.snapshot, match.snapshot)
                ),
                None,
            )
            if selected is None:
                raise GrayhavenBackupctlError(
                    f"No {args.repo} snapshot contains {requested_path}"
                )
            print_paths(
                service.list_snapshot_contents(
                    selected.repo,
                    selected.snapshot.id,
                    selected.matched_path,
                    recursive=args.recursive,
                )
            )
        elif args.command == "find":
            requested_paths = read_requested_paths(args)
            print_matches(
                service.find_matches(
                    args.repo,
                    requested_paths,
                    since=parse_human_time(args.since),
                    until=parse_human_time(args.until),
                )
            )
        elif args.command == "restore":
            requested_paths = read_requested_paths(args)
            target_dir = (
                pathlib.Path.cwd()
                if args.target is None
                else pathlib.Path(args.target).resolve(strict=False)
            )
            if args.as_of and args.until:
                raise GrayhavenBackupctlError(
                    "--as-of and --until cannot be used together"
                )
            if args.as_of and args.snapshot != "latest":
                raise GrayhavenBackupctlError(
                    "--as-of can only be used with latest restore selection"
                )
            since = parse_human_time(args.since)
            until = (
                parse_human_time(args.as_of)
                if args.as_of
                else parse_human_time(args.until)
            )
            plan = service.resolve_restore_plan(
                args.repo,
                args.snapshot,
                requested_paths,
                target_dir,
                args.in_place,
                since=since,
                until=until,
            )
            service.restore(plan, force=args.force, verbose=args.verbose)
        elif args.command == "backup":
            service.backup(args.repo, verbose=args.verbose)
    except GrayhavenBackupctlError as exc:
        print(f"grayhaven-backupctl: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
